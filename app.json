{
  "expo": {
    "name": "SNBX Pro",
    "slug": "snbx-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/snbx-logo.png",
    "scheme": "snbxapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/snbx-logo.png",
        "monochromeImage": "./assets/images/snbx-logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.snbxjayar.snbxapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/snbx-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "android": {
            "image": "./assets/images/snbx-logo.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "310a9b65-1c14-432f-af82-535fce414320"
      }
    }
  }
}
